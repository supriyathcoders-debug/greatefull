# GrowthHub365 / CRM (server only — use .env.local, never commit secrets)
#
# Use EITHER a workflow inbound webhook OR API credentials.

# Option A — paste an inbound webhook URL from a GrowthHub365 workflow (recommended if available).
# The POST body includes: submittedAt, form, fullName, email, phone?, company?, message, service?, metadata?
GROWTHHUB365_WEBHOOK_URL=

# Option B — Private integration token + Location ID (LeadConnector-style API used by many white-label CRMs).
GROWTHHUB365_ACCESS_TOKEN=
GROWTHHUB365_LOCATION_ID=

# Optional overrides if GrowthHub365 support gives you a different API host or version header.
# GROWTHHUB365_API_BASE=https://services.leadconnectorhq.com
# GROWTHHUB365_API_VERSION=2021-07-28

# Optional: UUID of a contact custom field where the full inquiry text should be stored (avoids truncation on "source").
# GROWTHHUB365_MESSAGE_CUSTOM_FIELD_ID=

# Optional: after creating a contact, also create an opportunity in this pipeline stage.
# GROWTHHUB365_PIPELINE_ID=
# GROWTHHUB365_PIPELINE_STAGE_ID=
